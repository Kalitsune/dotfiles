# typeset -A git_alias_expand=()

# misc
alias gpl="git pull"
alias grh="git reset --hard"
alias grs="git reset --soft"

# git add
alias ga="git add"
alias gaa="ga -A"

# status
alias gs="git status"
alias gss="gs --short"

# commits
alias gc="git commit"
alias gca="git commit --amend --no-edit"

# push
alias gp="git push"
alias gpt="gp --follow-tags"
alias gpf="gp --force-with-lease"
alias gpft="gpf --follow-tags"
alias gptf="gpft"

